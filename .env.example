CAMERA_INDEX=0

# Use 0 for the built-in webcam.
# For a USB camera try 1 or 2.
# For a WiFi/IP camera use an RTSP or HTTP stream URL, for example:
# CAMERA_SOURCE=rtsp://username:password@192.168.1.50:554/stream1
CAMERA_SOURCE=0

ABSENT_MARK_TIME=14:00
APP_TIMEZONE=Asia/Kolkata
PORT=3001
PYTHON_PATH=python-engine/venv/bin/python
DB_PATH=attendance.db

# Optional. Set this before exposing /api/attendance/mark publicly.
EDGE_API_KEY=change-me-before-production
